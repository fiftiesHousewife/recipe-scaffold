package {{package}};

import org.junit.jupiter.api.Test;

import java.io.IOException;
import java.io.InputStream;
import java.nio.charset.StandardCharsets;

import static org.assertj.core.api.Assertions.assertThat;

class {{recipeName}}Test {

    // Manifest-shape smoke test. Verifies the YAML composition file ships at the
    // expected classpath location and contains the expected identifiers, without
    // depending on any particular OpenRewrite Environment loader behaviour. The
    // composition is exercised end-to-end by the smokeTest matrix and by
    // anything that imports the published artifact and lists this recipe.
    @Test
    void manifestExistsAndDeclaresExpectedShape() throws IOException {
        try (InputStream in = getClass().getResourceAsStream("/META-INF/rewrite/{{recipeKebab}}.yml")) {
            assertThat(in)
                    .as("manifest at /META-INF/rewrite/{{recipeKebab}}.yml")
                    .isNotNull();
            String manifest = new String(in.readAllBytes(), StandardCharsets.UTF_8);
            assertThat(manifest)
                    .contains("type: specs.openrewrite.org/v1beta/recipe")
                    .contains("name: {{recipeId}}")
                    .contains("recipeList:");
        }
    }
}
